generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  BUYER
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PARTIALLY_ACCEPTED
  REJECTED
  PAYMENT_CONFIRMED
  COMPLETED
}

enum OrderItemStatus {
  PENDING
  ACCEPTED
  REJECTED
  PURCHASED
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          Role     @default(BUYER)
  active        Boolean  @default(true)
  walletBalance Decimal  @default(0) @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  wishlistItems WishlistItem[]
  orders        Order[]
}

model CardSet {
  id          String   @id @default(cuid())
  tcgId       String   @unique
  slug        String   @unique
  nameEn      String
  nameJp      String?
  releaseDate String?
  totalCards  Int?
  logoUrl     String?
  symbolUrl   String?
  sourceUrl   String?
  createdAt   DateTime @default(now())

  cards Card[]
}

model Card {
  id             String   @id @default(cuid())
  externalId     String   @unique
  name           String
  nameJp         String?
  setName        String
  setId          String
  number         String?
  rarity         String?
  imageUrl       String?
  hp             String?
  cardTypes      String[] @default([])
  cardCategory   String?
  illustrator    String?
  pokedexNumber  String?
  weakness       String?
  resistance     String?
  retreatCost    Int?
  regulationMark String?
  attacks        Json?
  price          Decimal? @db.Decimal(10, 2)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cardSetId     String?
  cardSet       CardSet?       @relation(fields: [cardSetId], references: [id])
  wishlistItems WishlistItem[]
  orderItems    OrderItem[]
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  cardId    String
  quantity  Int      @default(1)
  userPrice Decimal? @db.Decimal(10, 2)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id])
}

model Order {
  id          String      @id @default(cuid())
  orderNumber Int         @unique @default(autoincrement())
  userId      String
  status      OrderStatus @default(PENDING)
  paidAmount  Decimal?    @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]
}

model OrderItem {
  id         String          @id @default(cuid())
  orderId    String
  cardId     String
  quantity   Int             @default(1)
  userPrice  Decimal         @db.Decimal(10, 2)
  adminPrice Decimal?        @db.Decimal(10, 2)
  finalPrice Decimal?        @db.Decimal(10, 2)
  status     OrderItemStatus @default(PENDING)
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  order  Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  card   Card        @relation(fields: [cardId], references: [id])
  photos CardPhoto[]
}

model CardPhoto {
  id          String   @id @default(cuid())
  orderItemId String
  imageUrl    String
  caption     String?
  uploadedAt  DateTime @default(now())

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

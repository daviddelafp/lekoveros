# PostgreSQL — en producción usa Neon (neon.tech)
DATABASE_URL="postgresql://user:password@host/lekoveros?sslmode=require"

# NextAuth — genera un secreto con: openssl rand -hex 32
AUTH_SECRET="your-secret-here"

# URL pública de la app (Vercel te la da automáticamente como VERCEL_URL)
NEXTAUTH_URL="https://tu-app.vercel.app"

# Opcional — API de Pokemon TCG
POKEMON_TCG_API_KEY=""
